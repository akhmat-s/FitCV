# FitCV environment configuration — copy to `.env` and fill in your values.
# `.env` is gitignored; never commit your real key.

# Required: your OpenRouter API key (server-side only, never sent to the UI).
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: model id used for all generation steps.
MODEL_NAME=google/gemini-3.5-flash

# Optional: OpenAI-compatible base URL.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: where the Streamlit UI reaches the backend.
API_BASE_URL=http://localhost:8000
